+/* Invalidate virtio-snd's bypass flag (forces the slow AUD_write path).
+ * Resolved weakly so test-audio (which doesn't link virtio-snd) still
+ * links - when unresolved we're a no-op. */
+static void coreaudio_invalidate_bypass(const char *reason)
+{
+    extern void virtio_snd_bypass_invalidate(const char *) __attribute__((weak_import));
+    if (&virtio_snd_bypass_invalidate) {
+        virtio_snd_bypass_invalidate(reason);
+    }
+}
