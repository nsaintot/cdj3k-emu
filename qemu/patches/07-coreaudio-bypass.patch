+/* Static device latency in frames: kAudioDevicePropertyLatency +
+ * kAudioDevicePropertySafetyOffset. Captures the USB transit + DAC
+ * pipeline (Focusrite, etc.) - typically 10-30ms on USB interfaces.
+ * Added to the dynamic HAL depth to get the full host audio latency. */
+static _Atomic uint32_t g_coreaudio_static_latency_frames;
+
+uint32_t coreaudio_get_static_latency_frames(void);
+uint32_t coreaudio_get_static_latency_frames(void)
+{
+    return atomic_load_explicit(&g_coreaudio_static_latency_frames,
+                                memory_order_relaxed);
+}
