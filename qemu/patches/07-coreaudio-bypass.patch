+/* HAL listener: device's nominal rate changed under us (user opened AMS,
+ * another app bumped it - notably Audio Hijack forces 44100 Hz when
+ * starting a session - BT renegotiated, etc.).
+ *
+ * We deliberately do NOT invalidate the bypass here anymore. Earlier
+ * versions did, but in practice the auto-invalidate is harmful: the
+ * AUD_write fallback's resampler glitches audibly ("prrt prrt prrt" on
+ * each transient) whereas the bypass path running with a mildly wrong
+ * rate just produces a continuous pitch shift, which is way less
+ * obtrusive AND lets the user successfully record through recording
+ * tools that flip the device rate. The next virtio-snd PCM prepare
+ * will re-gate bypass with the fresh cached rate; until then,
+ * continuous-if-slightly-off audio is the right tradeoff.
+ *
+ * We still refresh the cached samplerate so virtio_snd_bypass_depth_frames
+ * (and thus the guest's audio_latency_ms sysfs) stays accurate. */
+static OSStatus handle_rate_change(AudioObjectID in_object_id,
+                                   UInt32 in_number_addresses,
+                                   const AudioObjectPropertyAddress *in_addresses,
+                                   void *in_client_data)
+{
+    (void)in_number_addresses;
+    (void)in_addresses;
+    (void)in_client_data;
+    coreaudio_refresh_cached_samplerate(in_object_id);
+    return noErr;
+}
