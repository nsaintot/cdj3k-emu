+/* cdj3k-emu: cached current nominal sample rate of the bound device.
+ * The original implementation issued a synchronous HAL property read on
+ * every call. Because the guest pulls virtio-snd config (and thus this
+ * value, via virtio_snd_bypass_depth_frames) from a sysfs polling loop,
+ * those reads landed on the BQL thread under contention - each one
+ * 100-500 us nominal, occasionally several ms when coreaudiod is busy -
+ * and starved the bypass-ring refill cadence, producing audible pops.
+ * Now this is a single atomic load: the value is seeded by
+ * init_out_device and kept fresh by the rate-change HAL listener
+ * (handle_rate_change), which fires off-BQL. */
+static _Atomic uint32_t g_coreaudio_cached_samplerate;
+
+/* Re-query the device's nominal rate and update the cache. Safe to call
+ * from any thread: AudioObjectGetPropertyData is thread-safe and the
+ * cache write is a single atomic store. Returns the rate it stored, or
+ * 0 if the read failed (in which case the cache is also zeroed). */
+static unsigned coreaudio_refresh_cached_samplerate(AudioDeviceID device_id)
+{
+    if (device_id == kAudioDeviceUnknown) {
+        atomic_store_explicit(&g_coreaudio_cached_samplerate, 0,
+                              memory_order_relaxed);
+        return 0;
+    }
+    Float64 rate = 0;
+    UInt32 size = sizeof(rate);
+    OSStatus status = AudioObjectGetPropertyData(device_id, &device_rate_addr,
+                                                 0, NULL, &size, &rate);
+    unsigned u = (status == kAudioHardwareNoError && rate > 0)
+                     ? (unsigned)rate : 0;
+    atomic_store_explicit(&g_coreaudio_cached_samplerate, u,
+                          memory_order_relaxed);
+    return u;
+}
+
+/* Hot-path accessor. Used by virtio-snd's config-read path (every guest
+ * sysfs poll). Must be lock-free and syscall-free - see comment above. */
+unsigned coreaudio_get_active_samplerate(void);
+unsigned coreaudio_get_active_samplerate(void)
+{
+    return atomic_load_explicit(&g_coreaudio_cached_samplerate,
+                                memory_order_relaxed);
+}
