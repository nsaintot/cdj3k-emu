+ * between when IOProc fills a buffer and when the DAC will play it -
+ * i.e. the CoreAudio HAL output queue depth. Read by virtio-snd to
+ * expose to the guest via config space. */
+static _Atomic uint32_t g_coreaudio_pipeline_depth_us;
+
+uint32_t coreaudio_get_pipeline_depth_us(void);
+uint32_t coreaudio_get_pipeline_depth_us(void)
+{
+    return atomic_load_explicit(&g_coreaudio_pipeline_depth_us,
+                                memory_order_relaxed);
+}
