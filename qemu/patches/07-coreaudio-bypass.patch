+/* Resolve a CoreAudio device UID to its AudioDeviceID. Returns
+ * kAudioDeviceUnknown if the UID doesn't match any live device. */
+static AudioDeviceID coreaudio_resolve_uid(const char *uid_cstr)
+{
+    if (!uid_cstr || !uid_cstr[0]) {
+        return kAudioDeviceUnknown;
+    }
+    CFStringRef uid = CFStringCreateWithCString(NULL, uid_cstr,
+                                                kCFStringEncodingUTF8);
+    if (!uid) {
+        return kAudioDeviceUnknown;
+    }
+    AudioObjectPropertyAddress addr = {
+        kAudioHardwarePropertyTranslateUIDToDevice,
+        kAudioObjectPropertyScopeGlobal,
+        kAudioObjectPropertyElementMain
+    };
+    AudioDeviceID resolved = kAudioDeviceUnknown;
+    UInt32 sz = sizeof(resolved);
+    OSStatus st = AudioObjectGetPropertyData(kAudioObjectSystemObject,
+                                             &addr,
+                                             sizeof(uid), &uid,
+                                             &sz, &resolved);
+    CFRelease(uid);
+    if (st != kAudioHardwareNoError) {
+        return kAudioDeviceUnknown;
+    }
+    return resolved;
+}
